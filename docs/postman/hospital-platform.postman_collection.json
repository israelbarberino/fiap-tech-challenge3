{
  "info": {
    "name": "Hospital Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8081/api/v1/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"doctor1\",\n  \"password\": \"doctor123\"\n}"
        }
      }
    },
    {
      "name": "Appointments - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt}}" }
        ],
        "url": {
          "raw": "http://localhost:8081/api/v1/appointments",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "appointments"]
        }
      }
    },
    {
      "name": "GraphQL - History",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwt}}" }
        ],
        "url": {
          "raw": "http://localhost:8083/graphql",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8083",
          "path": ["graphql"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"query($patientId: ID!, $page: Int!, $size: Int!) { consultationHistory(filter: { patientId: $patientId }, page: $page, size: $size) { items { appointmentId patientId doctorId scheduledAt status notes } page size totalElements } }\",\n  \"variables\": {\n    \"patientId\": \"00000000-0000-0000-0000-000000000001\",\n    \"page\": 0,\n    \"size\": 10\n  }\n}"
        }
      }
    }
  ]
}
