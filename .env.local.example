# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hospital_platform
SPRING_DATASOURCE_USERNAME=hospital
SPRING_DATASOURCE_PASSWORD=hospital

# RabbitMQ
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=hospital
SPRING_RABBITMQ_PASSWORD=hospital

# JWT
APP_SECURITY_JWT_SECRET=change-me-in-local-please-use-a-very-long-secret-key-1234567890
APP_SECURITY_JWT_EXPIRATION_MINUTES=120

# Server port
# Set SERVER_PORT per service/environment, since application.yml reads SERVER_PORT.
# Examples: 8081 (appointment), 8082 (notification), 8083 (history)
SERVER_PORT=8081
