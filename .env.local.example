# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hospital_platform
SPRING_DATASOURCE_USERNAME=hospital
SPRING_DATASOURCE_PASSWORD=hospital

# RabbitMQ
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
